{
    "manifest_version": 3,
    "name": "Duck Note",
    "version": "1.0.0",
    "description": "A persistent floating sticky note that follows you across tabs and browser sessions.",
    "permissions": [
        "storage",
        "activeTab",
        "scripting",
        "tabs"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_icon": {
            "16": "icons/icon-16.png",
            "32": "icons/icon-32.png",
            "48": "icons/icon-48.png",
            "128": "icons/icon-128.png"
        }
    },
    "icons": {
        "16": "icons/icon-16.png",
        "32": "icons/icon-32.png",
        "48": "icons/icon-48.png",
        "128": "icons/icon-128.png"
    },
    "web_accessible_resources": [
        {
            "resources": [
                "icons/icon-128.png"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ]
}